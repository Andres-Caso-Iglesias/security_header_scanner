# Server Configuration
PORT=3000

# API Security
# Leave empty to disable API Key authentication
API_KEY=

# Rate Limiting
RATE_LIMIT_MAX=20
RATE_LIMIT_WINDOW_MS=60000

# CORS
# Set to "*" to allow all origins (not recommended for production)
CORS_ORIGIN=http://localhost:5173

# Database (SQLite)
DB_PATH=data/scans.db

# Timeouts (milliseconds)
TIMEOUT_HTTP_CLIENT=10000
TIMEOUT_PAGE_FETCH=8000
TIMEOUT_TLS=8000
TIMEOUT_DNS=5000
TIMEOUT_SECURITY_FILE=5000
TIMEOUT_SENSITIVE_FILE=4000
TIMEOUT_SRI=10000
TIMEOUT_CVE_API=8000
